{
  "info": {
    "name": "CargoBit Admin Payouts API",
    "description": "Task 3.1 Payouts - Admin API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "admin_jwt",
      "value": "your_admin_jwt_token"
    },
    {
      "key": "payout_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Payouts",
      "item": [
        {
          "name": "Create Payout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"shipper_123\",\n  \"amountCents\": 5000,\n  \"currency\": \"EUR\",\n  \"idempotencyKey\": \"payout_shipper_123_20260421_v1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/payouts",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has payout id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.payout.id).to.exist;",
                  "    pm.environment.set('payout_id', jsonData.payout.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Payouts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/payouts?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "status",
                  "value": "PAID",
                  "disabled": true
                },
                {
                  "key": "userId",
                  "value": "shipper_123",
                  "disabled": true
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payout Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/payouts/{{payout_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts", "{{payout_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has payout details', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data.payout.id).to.eql(pm.environment.get('payout_id'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Retry Failed Payout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/payouts/{{payout_id}}/retry",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts", "{{payout_id}}", "retry"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response indicates retry success', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel Payout",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/payouts/{{payout_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts", "{{payout_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response indicates cancellation', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.payout.status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "Create Payout - Insufficient Balance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user_with_low_balance\",\n  \"amountCents\": 10000000,\n  \"currency\": \"EUR\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/payouts",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error code is INSUFFICIENT_BALANCE', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql('INSUFFICIENT_BALANCE');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payout - Invalid Amount",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"shipper_123\",\n  \"amountCents\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/payouts",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error code is INVALID_AMOUNT', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql('INVALID_AMOUNT');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Retry Payout - Not Failed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_jwt}}"
              },
              {
                "key": "x-user-id",
                "value": "admin_user_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/payouts/{{payout_id}}/retry",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "payouts", "{{payout_id}}", "retry"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error code is NOT_FAILED', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql('NOT_FAILED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
