{
  "info": {
    "name": "CargoBit Reconciliation API - Staging",
    "description": "E2E Tests für Payout Reconciliation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://payments.staging.cargobit.io",
      "type": "string"
    },
    {
      "key": "admin_jwt",
      "value": "{{admin_jwt}}",
      "type": "string"
    },
    {
      "key": "payout_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "Health Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Reconciliation",
      "item": [
        {
          "name": "List Open Payouts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success true', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.collectionVariables.set('payout_id', jsonData.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/open?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "open"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Get Reconciliation Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Report has required fields', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('total_open');",
                  "    pm.expect(jsonData.data).to.have.property('by_status');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/report",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "report"]
            }
          }
        },
        {
          "name": "Trigger Manual Reconciliation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "trigger"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Mark Payout",
      "item": [
        {
          "name": "Mark Payout as Resolved",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has ok true', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.ok).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"note\": \"Manual resolution via E2E test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/{{payout_id}}/mark",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "{{payout_id}}", "mark"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Error Cases",
      "item": [
        {
          "name": "Unauthorized Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/open",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "open"]
            }
          }
        },
        {
          "name": "Invalid Status Value",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"invalid_status\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/{{payout_id}}/mark",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "{{payout_id}}", "mark"]
            }
          }
        },
        {
          "name": "Payout Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reconciliation/non-existent-id/mark",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reconciliation", "non-existent-id", "mark"]
            }
          }
        }
      ]
    }
  ]
}
