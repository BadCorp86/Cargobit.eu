// CargoBit Platform - Prisma Schema
// European Logistics Marketplace - Full Relational Model
// Version: 2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  SUPPORT
  SHIPPER_COMPANY
  SHIPPER_PRIVATE
  DISPATCHER
  DRIVER_SELF_EMPLOYED
  MARKETER
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
  SUSPENDED
}

enum CompanyType {
  SHIPPER
  CARRIER
  BOTH
}

enum CompanyStatus {
  ACTIVE
  PENDING
  SUSPENDED
  INACTIVE
}

enum VerificationType {
  KYC
  KYB
  DRIVER_LICENSE
  ADR
  VEHICLE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SecurityFlagType {
  FRAUD_SUSPECTED
  PAYMENT_ISSUE
  DOCUMENT_ISSUE
  SUSPICIOUS_ACTIVITY
}

enum SecurityFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VehicleType {
  SPRINTER
  KOEFFER
  PLANE
  CURTAINSIDER
  KIPPER
  SILO
  MULDE
  TANKAUFLIEGER
  AUTOTRANSPORTER
  TIEFLADER
  TIEFBETT
  CONTAINERCHASSIS
  REEFER
  IBC_TRANSPORTER
  LANGAUFLIEGER
  JUMBO
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum TransportType {
  PALLET
  BULK
  LIQUID
  OVERSIZE
  LOWLOADER
  CAR_TRANSPORT
  COOLING
  HAZMAT
  CONTAINER
}

enum TransportStatus {
  CREATED
  PUBLISHED
  ASSIGNED
  IN_TRANSIT
  PICKUP_DONE
  DELIVERY_DONE
  COMPLETED
  CANCELLED
}

enum MatchingSessionStatus {
  STARTED
  RUNNING
  STOPPED
  COMPLETED
}

enum MatchingCandidateStatus {
  PENDING
  NOTIFIED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum WalletStatus {
  ACTIVE
  FROZEN
  INACTIVE
}

enum TransactionType {
  DEPOSIT
  PAYOUT
  FEE
  COMMISSION
  PAYMENT_IN
  PAYMENT_OUT
  REFUND
}

enum PlanName {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PAYOUT
  FRAUD_ALERT
}

// ============================================
// 1. KERNOBJEKTE: USERS, ROLES, COMPANIES
// ============================================

model Role {
  id          String      @id @default(cuid())
  name        UserRole    @unique
  description String?
  createdAt   DateTime    @default(now())
  
  userRoles   UserRoleRelation[]
  
  @@index([name])
}

model UserRoleRelation {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phone           String?
  language        String    @default("de")
  status          UserStatus @default(PENDING)
  
  // Timestamps
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  roles           UserRoleRelation[]
  companyUsers    CompanyUser[]
  driver          Driver?
  verifications   Verification[]
  securityFlags   SecurityFlag[]
  addresses       Address[]
  wallet          Wallet?
  
  // Shipper relations
  transportsAsShipper   Transport[]         @relation("ShipperTransports")
  
  // Notifications & Support
  notifications   Notification[]
  supportTickets SupportTicket[]
  auditLogs       AuditLog[]
  
  // Marketing (for MARKETER role)
  campaigns       Campaign[]
  
  @@index([email])
  @@index([status])
}

model Company {
  id                  String        @id @default(cuid())
  name                String
  type                CompanyType   @default(SHIPPER)
  vatNumber           String?       @unique
  registrationNumber  String?
  country             String
  status              CompanyStatus @default(PENDING)
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  // Relations
  companyUsers        CompanyUser[]
  vehicles            Vehicle[]
  drivers             Driver[]
  addresses           Address[]
  plans               CompanyPlan[]
  campaigns           Campaign[]
  wallets             Wallet[]
  
  @@index([name])
  @@index([country])
}

model CompanyUser {
  companyId     String
  userId        String
  roleInCompany String    @default("member") // owner, admin, member
  createdAt     DateTime  @default(now())
  
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

// ============================================
// 2. VERIFIKATION, KYC/KYB, SICHERHEIT
// ============================================

model Verification {
  id              String            @id @default(cuid())
  userId          String
  type            VerificationType
  status          VerificationStatus @default(PENDING)
  documentUrl     String?
  documentType    String?
  rejectionReason String?
  
  reviewedAt      DateTime?
  reviewedBy      String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([status])
}

model SecurityFlag {
  id          String                @id @default(cuid())
  userId      String
  type        SecurityFlagType
  severity    SecurityFlagSeverity  @default(MEDIUM)
  active      Boolean               @default(true)
  notes       String?
  
  createdAt   DateTime              @default(now())
  resolvedAt  DateTime?
  
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([active])
}

// ============================================
// 3. FAHRZEUGE, FAHRER, FLOTTEN
// ============================================

model Vehicle {
  id              String        @id @default(cuid())
  companyId       String
  
  // Vehicle details
  type            VehicleType
  plateNumber     String        @unique
  brand           String?
  model           String?
  year            Int?
  
  // Dimensions & Capacity
  lengthM         Float?
  widthM          Float?
  heightM         Float?
  maxPayloadKg    Float?
  volumeM3        Float?
  palletSpaces    Int?
  
  // Features
  adrApproved     Boolean       @default(false)
  adrClasses      String?       // JSON array of ADR classes
  coolingAvailable Boolean      @default(false)
  coolingMinTemp  Float?        // Minimum temperature (°C)
  coolingMaxTemp  Float?        // Maximum temperature (°C)
  hasLift         Boolean       @default(false)
  hasCrane        Boolean       @default(false)
  hasTank         Boolean       @default(false)
  tankCapacityL   Float?
  
  // Tunnel codes for ADR
  tunnelCodes     String?       // JSON array
  
  // Status
  status          VehicleStatus @default(ACTIVE)
  currentLocation String?       // JSON: {lat, lng, timestamp, country}
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverVehicles  DriverVehicle[]
  offers          Offer[]
  assignments     Assignment[]
  matchingCandidates MatchingCandidate[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
}

model Driver {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  companyId               String?
  
  // License info
  licenseNumber           String?
  licenseClass            String?   // C, CE, C1, C1E, etc.
  licenseExpiry           DateTime?
  
  // Driver card
  driverCardNumber        String?
  driverCardExpiry        DateTime?
  
  // ADR
  adrLicense              Boolean   @default(false)
  adrClasses              String?   // JSON array
  adrExpiry               DateTime?
  
  // International
  internationalExperience Boolean   @default(false)
  
  // Stats
  ratingAvg               Float     @default(0)
  ratingCount             Int       @default(0)
  completedTransports     Int       @default(0)
  cancelledTransports     Int       @default(0)
  damageCount             Int       @default(0)
  lastDamageAt            DateTime?
  
  // Availability
  isAvailable             Boolean   @default(true)
  currentLocation         String?   // JSON: {lat, lng, timestamp, country}
  
  // Languages
  spokenLanguages         String?   // JSON array: ["de", "en", "pl"]
  
  // Experience
  yearsExperience         Int?
  vehicleExperience       String?   // JSON array of vehicle types
  countryExperience       String?   // JSON array of countries
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  
  // Relations
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company                 Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  driverVehicles          DriverVehicle[]
  driverPermissions       DriverPermission[]
  offers                  Offer[]
  assignments             Assignment[]
  matchingCandidates      MatchingCandidate[]
  trackingPoints          TrackingPoint[]
  
  @@index([userId])
  @@index([companyId])
  @@index([isAvailable])
}

model DriverVehicle {
  driverId    String
  vehicleId   String
  isPrimary   Boolean   @default(false)
  assignedAt  DateTime  @default(now())
  
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@id([driverId, vehicleId])
  @@index([driverId])
  @@index([vehicleId])
}

// ============================================
// 4. TRANSPORTE & TRANSPORTDETAILS
// ============================================

model Address {
  id          String    @id @default(cuid())
  userId      String?
  companyId   String?
  
  label       String?   // "Home", "Office", "Warehouse"
  contactName String?
  contactPhone String?
  street      String
  streetNumber String?
  postalCode  String
  city        String
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  isDefault   Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Transport relations
  pickupForTransports   Transport[]  @relation("PickupAddress")
  deliveryForTransports Transport[]  @relation("DeliveryAddress")
  
  @@index([userId])
  @@index([companyId])
  @@index([country])
}

model Transport {
  id                    String          @id @default(cuid())
  
  // Participants
  shipperUserId         String
  shipperCompanyId      String?
  
  // Type & Status
  transportType         TransportType
  status                TransportStatus @default(CREATED)
  
  // Addresses
  pickupAddressId       String
  deliveryAddressId     String
  
  // Schedule
  pickupDatetime        DateTime
  pickupTimeFrom        String?
  pickupTimeTo          String?
  deliveryDatetime      DateTime?
  deliveryTimeFrom      String?
  deliveryTimeTo        String?
  
  // Description
  description           String?
  
  // Distance & Duration
  distanceKm            Float?
  estimatedDuration     Int?      // minutes
  
  // Pricing
  shipperBudget         Float?
  agreedPrice           Float?
  currency              String          @default("EUR")
  
  // International
  isInternational       Boolean         @default(false)
  transitCountries      String?         // JSON array
  customsRequired       Boolean         @default(false)
  customsDocuments      String?         // JSON array
  
  // Route
  calculatedRoute       String?         // JSON: route details
  tollCosts             Float?
  
  // Timestamps
  publishedAt           DateTime?
  assignedAt            DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  shipperUser           User            @relation("ShipperTransports", fields: [shipperUserId], references: [id])
  pickupAddress         Address         @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddress       Address         @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])
  
  transportDetail       TransportDetail?
  matchingSessions      MatchingSession[]
  offers                Offer[]
  assignment            Assignment?
  statusHistory         TransportStatusHistory[]
  trackingPoints        TrackingPoint[]
  documents             Document[]
  commissions           Commission[]
  
  @@index([shipperUserId])
  @@index([status])
  @@index([transportType])
  @@index([pickupDatetime])
}

model TransportDetail {
  id            String    @id @default(cuid())
  transportId   String    @unique
  
  // JSON details based on transport type
  detailsJson   String    // JSON with type-specific fields
  
  // Requirements
  vehicleRequirements    String?   // JSON
  driverRequirements     String?   // JSON
  internationalRequirements String? // JSON
  specialRequirements    String?
  
  // Cargo info
  weightKg      Float?
  volumeM3      Float?
  isHazmat      Boolean   @default(false)
  isFragile     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
}

// ============================================
// 5. MATCHING, ANGEBOTE, ZUWEISUNG
// ============================================

model MatchingSession {
  id            String              @id @default(cuid())
  transportId   String
  status        MatchingSessionStatus @default(STARTED)
  autoAssign    Boolean             @default(false)
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  completedAt   DateTime?
  
  transport     Transport           @relation(fields: [transportId], references: [id], onDelete: Cascade)
  candidates    MatchingCandidate[]
  
  @@index([transportId])
  @@index([status])
}

model MatchingCandidate {
  id                    String                @id @default(cuid())
  matchingSessionId     String
  driverId              String
  vehicleId             String
  
  // Filter results
  hardFilterPassed      Boolean               @default(false)
  softRulesPassed       Boolean               @default(false)
  fraudSafe             Boolean               @default(true)
  internationalAllowed  Boolean               @default(true)
  
  // Score
  score                 Float                 @default(0)
  scoreBreakdown        String?               // JSON with detailed scores
  
  // Status
  status                MatchingCandidateStatus @default(PENDING)
  notifiedAt            DateTime?
  expiresAt             DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  matchingSession       MatchingSession       @relation(fields: [matchingSessionId], references: [id], onDelete: Cascade)
  driver                Driver                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle               Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@unique([matchingSessionId, driverId, vehicleId])
  @@index([matchingSessionId])
  @@index([driverId])
  @@index([score])
  @@index([status])
}

model Offer {
  id              String      @id @default(cuid())
  transportId     String
  driverId        String
  vehicleId       String
  
  price           Float
  currency        String      @default("EUR")
  message         String?
  estimatedDuration Int?
  
  status          OfferStatus @default(PENDING)
  
  validUntil      DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  transport       Transport   @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver          Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@unique([transportId, driverId])
  @@index([transportId])
  @@index([driverId])
  @@index([status])
}

model Assignment {
  id            String    @id @default(cuid())
  transportId   String    @unique
  driverId      String
  vehicleId     String
  assignedBy    String
  
  assignedAt    DateTime  @default(now())
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([driverId])
}

// ============================================
// 6. STATUS, TRACKING, DOKUMENTE
// ============================================

model TransportStatusHistory {
  id            String    @id @default(cuid())
  transportId   String
  status        TransportStatus
  changedBy     String?
  note          String?
  
  changedAt     DateTime  @default(now())
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([changedAt])
}

model TrackingPoint {
  id            String    @id @default(cuid())
  transportId   String
  driverId      String
  
  latitude      Float
  longitude     Float
  timestamp     DateTime  @default(now())
  
  speed         Float?    // km/h
  heading       Float?    // degrees
  
  transport     Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
  @@index([driverId])
  @@index([timestamp])
}

model Document {
  id            String    @id @default(cuid())
  transportId   String?
  
  type          String    // cmr, lieferschein, rechnung, foto_pickup, foto_delivery, pod
  name          String
  description   String?
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  
  isGenerated   Boolean   @default(false)
  isSigned      Boolean   @default(false)
  signedAt      DateTime?
  signedByUrl   String?
  
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  transport     Transport? @relation(fields: [transportId], references: [id], onDelete: SetNull)
  
  @@index([transportId])
  @@index([type])
}

// ============================================
// 7. WALLET, ZAHLUNGEN, GEBÜHREN
// ============================================

model Wallet {
  id              String        @id @default(cuid())
  ownerUserId     String?       @unique
  ownerCompanyId  String?       @unique
  
  balance         Float         @default(0)
  currency        String        @default("EUR")
  status          WalletStatus  @default(ACTIVE)
  
  // Stats
  totalDeposited  Float         @default(0)
  totalWithdrawn  Float         @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  user            User?         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]
  payoutMethods   PayoutMethod[]
  
  @@index([ownerUserId])
  @@index([ownerCompanyId])
  @@index([status])
}

model WalletTransaction {
  id                  String          @id @default(cuid())
  walletId            String
  type                TransactionType
  amount              Float
  currency            String          @default("EUR")
  
  relatedTransportId  String?
  description         String?
  reference           String?         // External reference
  
  processedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  
  createdAt           DateTime        @default(now())
  
  wallet              Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  @@index([walletId])
  @@index([type])
  @@index([relatedTransportId])
}

model PayoutMethod {
  id          String    @id @default(cuid())
  walletId    String
  
  iban        String
  holderName  String
  bic         String?
  verified    Boolean   @default(false)
  
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  wallet      Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  @@index([walletId])
}

model Commission {
  id                  String    @id @default(cuid())
  transportId         String
  
  plan                PlanName  @default(FREE)
  commissionPercent   Float
  commissionAmount    Float
  walletFeePercent    Float
  walletFeeAmount     Float
  
  createdAt           DateTime  @default(now())
  
  transport           Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  
  @@index([transportId])
}

// ============================================
// 8. PRICING, PLÄNE, MARKETING
// ============================================

model Plan {
  id                  String    @id @default(cuid())
  name                PlanName  @unique
  
  monthlyFee          Float     @default(0)
  yearlyFee           Float?
  currency            String    @default("EUR")
  
  // Commission rates
  commissionPercent   Float     @default(14)
  walletFeePercent    Float     @default(3.5)
  
  // Features (JSON)
  featuresJson        String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  companyPlans        CompanyPlan[]
  
  @@index([name])
}

model CompanyPlan {
  id          String    @id @default(cuid())
  companyId   String
  planId      String
  
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  
  createdAt   DateTime  @default(now())
  
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([planId])
}

model Campaign {
  id              String          @id @default(cuid())
  companyId       String?
  userId          String
  
  name            String
  description     String?
  
  position        String?         // banner_top, sidebar, listing_highlight
  bannerUrl       String?
  targetUrl       String?
  
  budget          Float           @default(0)
  spentAmount     Float           @default(0)
  currency        String          @default("EUR")
  
  status          CampaignStatus  @default(DRAFT)
  
  startDate       DateTime?
  endDate         DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats           CampaignStats[]
  
  @@index([companyId])
  @@index([userId])
  @@index([status])
}

model CampaignStats {
  id          String    @id @default(cuid())
  campaignId  String
  
  date        DateTime  @default(now())
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@unique([campaignId, date])
  @@index([campaignId])
}

// ============================================
// 9. SUPPORT, TICKETS, LOGS
// ============================================

model SupportTicket {
  id          String      @id @default(cuid())
  userId      String
  transportId String?
  
  subject     String
  description String
  priority    String      @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  status      TicketStatus @default(OPEN)
  category    String?
  
  assignedTo  String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportMessage[]
  
  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id          String    @id @default(cuid())
  ticketId    String
  senderId    String
  senderRole  String    // USER, SUPPORT, ADMIN
  
  message     String
  attachments String?   // JSON array of file URLs
  
  isInternal  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  @@index([ticketId])
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  
  action        AuditAction
  entityType    String      // user, transport, wallet, vehicle, etc.
  entityId      String?
  
  dataBefore    String?     // JSON
  dataAfter     String?     // JSON
  
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime    @default(now())
  
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================
// 10. NOTIFICATIONS
// ============================================

model Notification {
  id          String    @id @default(cuid())
  userId      String
  
  type        String    // NEW_OFFER, TRANSPORT_UPDATE, PAYMENT, etc.
  title       String
  message     String
  data        String?   // JSON with additional data
  
  isRead      Boolean   @default(false)
  readAt      DateTime?
  
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
}

// ============================================
// 11. DRIVER PERMISSIONS (International)
// ============================================

model DriverPermission {
  id              String    @id @default(cuid())
  driverId        String
  
  countryCode     String    // ISO 2-letter code
  countryName     String
  
  isAllowed       Boolean   @default(true)
  allowedAt       DateTime?
  expiresAt       DateTime?
  
  visaRequired    Boolean   @default(false)
  visaValid       Boolean   @default(false)
  visaExpiry      DateTime?
  
  tripsCompleted  Int       @default(0)
  lastTripAt      DateTime?
  
  documentUrl     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@unique([driverId, countryCode])
  @@index([driverId])
  @@index([countryCode])
  @@index([isAllowed])
}

// ============================================
// 12. TOLL SYSTEMS & BORDER CROSSINGS
// ============================================

model TollSystem {
  id              String    @id @default(cuid())
  countryCode     String
  countryName     String
  
  systemName      String    // Toll Collect, eToll, myto, etc.
  systemType      String    // DISTANCE, VIGNETTE, HYBRID
  
  euro5Rate       Float?    // Rate per km
  euro6Rate       Float?
  euro6eevRate    Float?
  
  vignetteDaily   Float?
  vignetteWeekly  Float?
  vignetteMonthly Float?
  vignetteYearly  Float?
  
  currency        String    @default("EUR")
  websiteUrl      String?
  description     String?
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([countryCode, systemName])
  @@index([countryCode])
}

model BorderCrossing {
  id              String    @id @default(cuid())
  
  fromCountry     String
  toCountry       String
  crossingName    String
  
  latitude        Float?
  longitude       Float?
  
  adrAllowed      Boolean   @default(true)
  tunnelCode      String?
  
  open24h         Boolean   @default(true)
  openingHours    String?   // JSON
  
  avgWaitMinutes  Int?
  
  customsRequired Boolean   @default(true)
  customsType     String?   // EU_INTERNAL, EU_EXTERNAL
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([fromCountry, toCountry, crossingName])
  @@index([fromCountry])
  @@index([toCountry])
}

// ============================================
// 13. SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String    // JSON
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([key])
}
