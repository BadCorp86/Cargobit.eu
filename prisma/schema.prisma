// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User roles in the CargoBit platform
enum UserRole {
  ADMIN
  DISPATCHER      // Disponent/Transportunternehmer
  DRIVER          // Fahrer
  SHIPPER         // Verlader/Auktionsersteller
  SUPPORT
}

// Membership tiers
enum MembershipTier {
  FREE          // Free tier for testing
  STARTER       // €89/month
  PROFESSIONAL  // €499/month
  ENTERPRISE    // €899/month
}

// User status
enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  VERIFIED
  BLOCKED
}

// Main User model
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  
  // Role and permissions
  role          UserRole       @default(DISPATCHER)
  status        UserStatus     @default(PENDING)
  
  // Company info (for dispatchers/shippers)
  companyName   String?
  companyAddress String?
  taxId         String?
  vatNumber     String?
  registrationNumber String?
  
  // Contact
  phone         String?
  
  // Membership
  membershipTier  MembershipTier @default(FREE)
  membershipStart DateTime?
  membershipEnd   DateTime?
  
  // Driver specific
  driverLicenseNumber String?
  driverLicenseExpiry DateTime?
  driverLicenseClass  String?
  driverCardExpiry    DateTime?
  adrCertificate      String?
  
  // GPS/Location
  currentLat    Float?
  currentLng    Float?
  lastLocationUpdate DateTime?
  
  // Wallet
  walletBalance Float          @default(0)
  
  // Blocking (for moderation violations or non-payment)
  isBlocked     Boolean        @default(false)
  blockReason   String?
  blockedAt     DateTime?
  blockedBy     String?        // Admin user ID
  
  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  shipmentsAsSender    Shipment[]      @relation("ShipmentsAsSender")
  shipmentsAsCarrier   Shipment[]      @relation("ShipmentsAsCarrier")
  shipmentsAsDriver    Shipment[]      @relation("ShipmentsAsDriver")
  vehicles             Vehicle[]
  documents            Document[]
  walletTransactions   WalletTransaction[]
  supportTickets       SupportTicket[] @relation("SupportTicketsByUser")
  assignedTickets      SupportTicket[] @relation("SupportTicketsAssigned")
  moderationResults    ModerationResult[]
  invoices             Invoice[]
  adCampaigns          AdCampaign[]
  adApplications       AdApplication[]
  
  @@map("users")
}

// Vehicle model for fleet management
model Vehicle {
  id            String   @id @default(cuid())
  userId        String
  
  // Vehicle details
  plateNumber   String   @unique
  vehicleType   String   // Sprinter, LKW 7.5t, LKW 18t, LKW 40t, etc.
  brand         String?
  model         String?
  year          Int?
  
  // Capacity
  maxWeight     Float    // in kg
  maxVolume     Float    // in m³
  length        Float?   // in meters
  width         Float?   // in meters
  height        Float?   // in meters
  
  // Equipment
  hasLift       Boolean  @default(false)
  hasCooling    Boolean  @default(false)
  adrCertified  Boolean  @default(false)
  
  // Status
  isActive      Boolean  @default(true)
  lastInspection DateTime?
  nextInspection DateTime?
  
  // GPS tracking
  currentLat    Float?
  currentLng    Float?
  lastUpdate    DateTime?
  
  // Capacity tracking
  capacity      VehicleCapacity?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("vehicles")
}

// Shipment model
model Shipment {
  id                String        @id @default(cuid())
  shipmentNumber    String        @unique // CB-2024-1847 format
  
  // Sender (Shipper)
  senderId          String
  senderName        String
  senderAddress     String
  senderContact     String?
  
  // Receiver
  receiverName      String
  receiverAddress   String
  receiverContact   String?
  
  // Carrier (Dispatcher)
  carrierId         String?
  carrierName       String?
  
  // Driver
  driverId          String?
  driverName        String?
  vehicleId         String?
  vehiclePlate      String?
  
  // Route
  pickupPlace       String
  pickupDate        DateTime
  pickupTime        String?
  deliveryPlace     String
  deliveryDate      DateTime?
  deliveryTime      String?
  
  // Goods
  goodsDescription  String
  weight            Float         // in kg
  volume            Float?        // in m³
  packages          Int           @default(1)
  specialInstructions String?
  
  // Pricing
  price             Float
  currency          String        @default("EUR")
  platformFee       Float         @default(0)
  carrierNetPrice   Float?        // price minus platform fee
  
  // Type
  shipmentType      String        @default("direct") // direct, auction
  auctionId         String?
  
  // Status
  status            String        @default("pending") // pending, assigned, in_transit, delivered, cancelled
  
  // Tracking
  currentLat        Float?
  currentLng        Float?
  lastTrackingUpdate DateTime?
  
  // Delivery confirmation
  deliveredAt       DateTime?
  deliverySignature String?       // base64 signature image
  deliveryGpsLat    Float?
  deliveryGpsLng    Float?
  deliveryPhoto     String?       // base64 photo
  
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  // Relations
  sender            User          @relation("ShipmentsAsSender", fields: [senderId], references: [id])
  carrier           User?         @relation("ShipmentsAsCarrier", fields: [carrierId], references: [id])
  driver            User?         @relation("ShipmentsAsDriver", fields: [driverId], references: [id])
  eCMR              ECMR?
  
  @@index([status])
  @@index([senderId])
  @@index([carrierId])
  @@index([driverId])
  @@map("shipments")
}

// e-CMR (Electronic Waybill)
model ECMR {
  id                String    @id @default(cuid())
  ecmrNumber        String    @unique // eCMR-2025-001234 format
  
  // Linked shipment
  shipmentId        String    @unique
  
  // Parties
  senderName        String
  senderAddress     String
  senderContact     String?
  
  receiverName      String
  receiverAddress   String
  receiverContact   String?
  
  carrierName       String
  carrierAddress    String
  carrierContact    String?
  
  // Transport details
  vehiclePlate      String
  driverName        String
  pickupPlace       String
  pickupDate        DateTime
  deliveryPlace     String
  deliveryDate      DateTime?
  
  // Goods
  goodsDescription  String
  weight            Float
  volume            Float?
  packages          Int        @default(1)
  specialInstructions String?
  
  // Status
  status            String     @default("draft") // draft, active, completed, archived
  
  // Blockchain
  blockchainHash    String?    // Hash stored on blockchain
  blockchainNetwork String?    @default("ethereum")
  blockchainTxHash  String?    // Transaction hash
  blockchainTimestamp DateTime?
  
  // Digital signatures
  senderSignature   String?    // base64 signature
  senderSignedAt    DateTime?
  senderGpsLat      Float?
  senderGpsLng      Float?
  
  carrierSignature  String?    // base64 signature
  carrierSignedAt   DateTime?
  carrierGpsLat     Float?
  carrierGpsLng     Float?
  
  receiverSignature String?    // base64 signature
  receiverSignedAt  DateTime?
  receiverGpsLat    Float?
  receiverGpsLng    Float?
  
  // Document storage
  pdfUrl            String?    // URL to stored PDF
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  shipment          Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  @@map("ecmrs")
}

// Document model for ODC
model Document {
  id              String    @id @default(cuid())
  userId          String
  
  // Document type
  documentType    String    // frachtbrief, fuehrerschein, company, driver_docs
  
  // Original file
  fileName        String
  fileUrl         String    // base64 or URL
  fileSize        Int?
  mimeType        String?
  
  // OCR results
  extractedData   String?   // JSON string of extracted data
  confidence      Float?    // 0-1
  warnings        String?   // JSON array of warnings
  
  // Processing status
  status          String    @default("pending") // pending, processed, failed
  
  // Verification
  isVerified      Boolean   @default(false)
  verifiedBy      String?   // Admin user ID
  verifiedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([documentType])
  @@map("documents")
}

// Wallet transactions
model WalletTransaction {
  id              String    @id @default(cuid())
  userId          String
  
  // Transaction details
  type            String    // deposit, withdrawal, fee, payout, refund
  amount          Float
  currency        String    @default("EUR")
  
  // Reference
  referenceType   String?   // shipment, auction, membership
  referenceId     String?
  
  // Status
  status          String    @default("pending") // pending, completed, failed, cancelled
  
  // Payment method for deposits
  paymentMethod   String?   // sepa, credit_card, paypal
  
  // For withdrawals
  bankAccount     String?   // IBAN (masked)
  bankName        String?
  
  // Fees
  platformFee     Float     @default(0)
  walletFee       Float     @default(0) // Wallet fee for dispatchers only
  
  description     String?
  
  createdAt       DateTime  @default(now())
  processedAt     DateTime?
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("wallet_transactions")
}

// Support tickets
model SupportTicket {
  id              String    @id @default(cuid())
  ticketNumber    String    @unique
  
  // Users
  createdById     String
  assignedToId    String?
  
  // Ticket details
  subject         String
  description     String
  category        String?   // technical, billing, shipment, other
  priority        String    @default("normal") // low, normal, high, urgent
  
  // Status
  status          String    @default("open") // open, in_progress, waiting, resolved, closed
  
  // Shipment reference
  shipmentId      String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?
  closedAt        DateTime?
  
  // Relations
  createdBy       User      @relation("SupportTicketsByUser", fields: [createdById], references: [id])
  assignedTo      User?     @relation("SupportTicketsAssigned", fields: [assignedToId], references: [id])
  messages        SupportMessage[]
  
  @@index([status])
  @@map("support_tickets")
}

// Support ticket messages
model SupportMessage {
  id              String    @id @default(cuid())
  ticketId        String
  
  // Sender
  senderId        String
  senderName      String
  senderRole      String
  
  // Message
  message         String
  attachments     String?   // JSON array of attachment URLs
  
  // Internal note (only visible to support staff)
  isInternal      Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  @@index([ticketId])
  @@map("support_messages")
}

// Audit log for admin actions
model AuditLog {
  id              String    @id @default(cuid())
  
  // Who performed the action
  userId          String
  userEmail       String
  userRole        String
  
  // Action details
  action          String    // user_create, user_update, shipment_create, etc.
  entityType      String    // user, shipment, ecmr, document
  entityId        String?
  
  // Changes
  oldValue        String?   // JSON
  newValue        String?   // JSON
  
  // Request info
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// System settings (key-value store)
model SystemSetting {
  id              String    @id @default(cuid())
  key             String    @unique
  value           String    // JSON value
  description     String?
  
  updatedAt       DateTime  @updatedAt
  
  @@map("system_settings")
}

// Vehicle Capacity - Real-time tracking of available space
model VehicleCapacity {
  id              String    @id @default(cuid())
  vehicleId       String    @unique
  
  // Current capacity
  availableWeight Float     @default(0)  // kg available
  availableVolume Float     @default(0)  // m³ available
  availablePallets Int      @default(0)  // pallet spaces available
  availableLength Float     @default(0)  // meters of loading space
  
  // Status
  status          String    @default("available") // available, partially_loaded, full, offline
  
  // Location when capacity was updated
  lat             Float?
  lng             Float?
  locationName    String?   // City name
  
  // Route info
  currentRoute    String?   // e.g., "Berlin → München"
  headingTo       String?   // Destination city
  
  // Timestamps
  updatedAt       DateTime  @updatedAt
  
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([lat, lng])
  @@map("vehicle_capacities")
}

// Express Transport Request - Instant transport alerts
model ExpressTransport {
  id              String    @id @default(cuid())
  
  // Creator (Shipper)
  creatorId       String
  creatorName     String
  creatorPhone    String?
  
  // Pickup
  pickupAddress   String
  pickupLat       Float
  pickupLng       Float
  pickupPlace     String    // City name
  pickupDeadline  DateTime  // Must be picked up by
  
  // Delivery
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryPlace   String?
  
  // Cargo
  weight          Float     // kg
  volume          Float?    // m³
  pallets         Int       @default(0)
  description     String
  specialRequirements String? // "Lift, ADR, Cooling"
  
  // Pricing
  offeredPrice    Float
  currency        String    @default("EUR")
  
  // Alert radius
  alertRadiusKm   Int       @default(20)  // Alert drivers within 20km
  
  // Status
  status          String    @default("active") // active, accepted, expired, cancelled
  
  // Accepted by
  acceptedById    String?
  acceptedByName  String?
  acceptedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  expiresAt       DateTime  // When the alert expires
  
  // Notifications sent
  notificationsSent Int     @default(0)
  
  @@index([status])
  @@index([pickupLat, pickupLng])
  @@map("express_transports")
}

// GPS Position History - Track movement
model GPSPosition {
  id              String    @id @default(cuid())
  
  // What is being tracked
  entityType      String    // user, vehicle, shipment
  entityId        String
  
  // Position
  lat             Float
  lng             Float
  accuracy        Float?    // meters
  speed           Float?    // km/h
  heading         Float?    // degrees 0-360
  altitude        Float?    // meters
  
  // Context
  locationName    String?   // City/address from reverse geocoding
  isMoving        Boolean   @default(false)
  
  // Battery/device info
  batteryLevel    Float?    // 0-1
  isCharging      Boolean   @default(false)
  
  // Timestamp
  recordedAt      DateTime  @default(now())
  
  @@index([entityType, entityId])
  @@index([recordedAt])
  @@map("gps_positions")
}

// Push Notification Token - For mobile apps
model PushToken {
  id              String    @id @default(cuid())
  userId          String
  
  // Device info
  deviceToken     String    @unique  // FCM token or APNS token
  platform        String    // android, ios, web
  deviceName      String?   // "iPhone 15 Pro", "Samsung Galaxy S24"
  deviceModel     String?
  osVersion       String?
  appVersion      String?
  
  // Preferences
  receiveExpress  Boolean   @default(true)  // Express transport alerts
  receiveShipment Boolean   @default(true)  // Shipment updates
  receiveChat     Boolean   @default(true)  // Chat messages
  receiveMarketing Boolean  @default(false) // Marketing
  
  // Status
  isActive        Boolean   @default(true)
  lastUsedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@map("push_tokens")
}

// Push Notification Log
model PushNotification {
  id              String    @id @default(cuid())
  
  // Recipient
  userId          String
  pushTokenId     String?
  
  // Content
  title           String
  body            String
  data            String?   // JSON payload
  
  // Type
  type            String    // express, shipment, chat, system
  
  // Status
  status          String    @default("pending") // pending, sent, delivered, failed
  sentAt          DateTime?
  deliveredAt     DateTime?
  error           String?
  
  // Related entity
  entityType      String?
  entityId        String?
  
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([status])
  @@map("push_notifications")
}

// Optimized Route - AI route suggestions
model OptimizedRoute {
  id              String    @id @default(cuid())
  
  // Vehicle/Driver
  vehicleId       String?
  driverId        String?
  
  // Route waypoints (JSON array)
  waypoints       String    // [{lat, lng, type: "pickup|delivery|depot", shipmentId}]
  
  // Optimization details
  totalDistance   Float     // km
  totalDuration   Int       // minutes
  totalStops      Int
  
  // Savings
  savedKm         Float     @default(0)  // km saved vs original
  savedMinutes    Int       @default(0)  // time saved
  savedEuros      Float     @default(0)  // fuel + time savings
  
  // AI recommendation
  aiRecommendation String?  // Explanation of the route
  
  // Status
  status          String    @default("suggested") // suggested, accepted, active, completed
  
  // Timestamps
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  @@index([driverId])
  @@index([status])
  @@map("optimized_routes")
}

// Capacity Alert - When someone needs capacity on a route
model CapacityAlert {
  id              String    @id @default(cuid())
  
  // Creator
  creatorId       String
  creatorType     String    // shipper, dispatcher
  
  // Route needed
  fromCity        String
  toCity          String?
  fromLat         Float?
  fromLng         Float?
  toLat           Float?
  toLng           Float?
  
  // What's needed
  weight          Float?
  volume          Float?
  pallets         Int?
  
  // When
  pickupDate      DateTime?
  flexible        Boolean   @default(false)
  
  // Budget
  maxPrice        Float?
  
  // Status
  status          String    @default("active") // active, matched, expired
  
  // Timestamps
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  
  @@index([status])
  @@index([fromLat, fromLng])
  @@map("capacity_alerts")
}

// Moderation Result - AI content moderation
model ModerationResult {
  id              String    @id @default(cuid())
  
  // What was moderated
  contentType     String    // image, video, text
  contentUrl      String?   // URL to the content
  contentBase64   String?   // Base64 if stored directly
  
  // Source
  userId          String
  entityType      String    // ad_campaign, profile_image, document
  entityId        String?
  
  // AI Analysis
  isViolating     Boolean   @default(false)
  violationTypes  String?   // JSON array: ["violence", "pornography", "hate_speech", "illegal"]
  confidence      Float?    // 0-1
  aiDescription   String?   // AI explanation
  
  // Action taken
  action          String    @default("none") // none, flagged, blocked, auto_blocked
  blockedAt       DateTime?
  
  // Manual review
  reviewedBy      String?   // Admin user ID
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewDecision  String?   // approved, rejected, pending
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isViolating])
  @@index([contentType])
  @@map("moderation_results")
}

// Invoice - Automatic billing for advertising
model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique // INV-2025-001234
  
  // User
  userId          String
  
  // Billing period
  periodStart     DateTime
  periodEnd       DateTime
  
  // Line items (JSON array)
  lineItems       String    // [{description, quantity, unitPrice, total}]
  
  // Totals
  subtotal        Float
  volumeDiscount  Float     @default(0)  // 10%, 20%, 30%
  discountPercent Int       @default(0)
  total          Float
  currency        String    @default("EUR")
  
  // Payment
  status          String    @default("pending") // pending, paid, overdue, cancelled
  paidAt          DateTime?
  paymentMethod   String?
  
  // Overdue handling
  dueDate         DateTime
  overdueNotices  Int       @default(0)
  blockedDueToNonPayment Boolean @default(false)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

// Ad Campaign - Advertising campaigns
model AdCampaign {
  id              String    @id @default(cuid())
  
  // Owner
  userId          String
  name            String
  
  // Content
  bannerUrl       String?
  bannerBase64    String?
  targetUrl       String
  position        String    // header, sidebar, dashboard, newsletter, popup, footer
  dimensions      String    // 728x90, 300x250, etc.
  
  // Budget
  budget          Float
  budgetUsed      Float     @default(0)
  dailyBudget     Float?
  
  // Stats
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  ctr             Float     @default(0)
  
  // Schedule
  startDate       DateTime
  endDate         DateTime?
  
  // Status
  status          String    @default("pending_review") // pending_review, active, paused, completed, rejected
  rejectionReason String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("ad_campaigns")
}

// Ad Application - Advertising application process
model AdApplication {
  id              String    @id @default(cuid())
  
  // Applicant
  userId          String
  companyName     String
  contactPerson   String
  email           String
  phone           String
  website         String?
  
  // Campaign info
  productDescription String?
  advertisedProduct  String?
  budgetRange        String?
  preferredPositions String?  // JSON array
  campaignDuration   String?
  additionalNotes    String?
  
  // Status
  status          String    @default("pending") // pending, approved, rejected
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("ad_applications")
}
