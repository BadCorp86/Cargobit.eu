+import { Injectable, Logger } from '@nestjs/common';
+import { Cron } from '@nestjs/schedule';
+import { ReconciliationService } from '../services/reconciliation.service';
+import { LeaderLock } from '../../infra/leader-lock.service';
+
+@Injectable()
+export class ReconciliationScheduler {
+  private readonly logger = new Logger(ReconciliationScheduler.name);
+
+  constructor(private readonly svc: ReconciliationService, private readonly lock: LeaderLock) {}
+
+  @Cron('0 */6 * * *')
+  async run() {
+    const key = 'reconciliation:leader';
+    if (!(await this.lock.acquire(key, 60))) {
+      this.logger.log('Not leader, skipping reconciliation run');
+      return;
+    }
+    try {
+      this.logger.log('Starting reconciliation run');
+      const open = await this.svc.listOpenPayouts();
+      this.logger.log(`Found ${open.length} open payouts`);
+    } finally {
+      await this.lock.release(key);
+    }
+  }
+}
+
