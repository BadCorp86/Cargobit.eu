+import { Injectable, Logger } from '@nestjs/common';
+import { InjectRepository } from '@nestjs/typeorm';
+import { Repository, Connection } from 'typeorm';
+import { Payout } from '../../payments/entities/payout.entity';
+import { PayoutEvent } from '../../payments/entities/payout-event.entity';
+import { AuditService } from '../../audit/audit.service';
+
+@Injectable()
+export class ReconciliationService {
+  private readonly logger = new Logger(ReconciliationService.name);
+
+  constructor(
+    @InjectRepository(Payout) private readonly payouts: Repository<Payout>,
+    @InjectRepository(PayoutEvent) private readonly events: Repository<PayoutEvent>,
+    private readonly audit: AuditService,
+    private readonly connection: Connection,
+  ) {}
+
+  async listOpenPayouts(): Promise<any[]> {
+    const rows = await this.payouts.find({ where: [{ status: 'pending' }, { status: 'processing' }] });
+    return rows.map(r => ({ id: r.id, amount_cents: r.amount_cents, status: r.status, diff: 0 }));
+  }
+
+  async markPayout(id: string, payload: { status: 'resolved' | 'needs_review'; note?: string }) {
+    return await this.connection.transaction(async manager => {
+      const p = await manager.findOne(Payout, { where: { id } });
+      if (!p) throw new Error('Payout not found');
+      p.status = payload.status === 'resolved' ? 'paid' : p.status;
+      await manager.save(p);
+      await manager.insert(PayoutEvent, { payout_id: id, type: 'manual_mark', payload });
+      await this.audit.recordTransactional(manager, 'reconciliation.mark', { payoutId: id, payload });
+      return { ok: true, payout: p };
+    });
+  }
+}
